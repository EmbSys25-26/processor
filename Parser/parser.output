Terminals unused in grammar

    TOKEN_ERROR


Grammar

    0 $accept: program $end

    1 program: program TOKEN_EOF
    2        | program global_statement
    3        | global_statement

    4 global_statement: type_declaration
    5                 | var_declaration
    6                 | function_prototype
    7                 | function_definition
    8                 | def_undef_definition
    9                 | TOKEN_SEMI

   10 local_statement_list: ε
   11                     | local_statement_list local_statement

   12 local_statement: selection_statement
   13                | iteration_statement
   14                | jump_statement
   15                | compound_statement
   16                | var_declaration
   17                | var_assignment
   18                | function_definition
   19                | exp TOKEN_SEMI

   20 def_undef_definition: define
   21                     | undef

   22 define: TOKEN_PP_DEFINE

   23 undef: TOKEN_PP_UNDEF

   24 selection_statement: if_statement
   25                    | switch_statement

   26 jump_statement: break_statement
   27               | return_statement
   28               | continue_statement

   29 iteration_statement: do_while_loop
   30                    | while_loop
   31                    | for_loop

   32 type_declaration: enum_declaration
   33                 | struct_declaration
   34                 | union_declaration

   35 compound_statement: TOKEN_LEFT_BRACE local_statement_list TOKEN_RIGHT_BRACE

   36 enum_declaration: TOKEN_ENUM TOKEN_ID TOKEN_LEFT_BRACE enum_member_list TOKEN_RIGHT_BRACE TOKEN_SEMI

   37 enum_member_list: enum_member
   38                 | enum_member_list TOKEN_COMMA enum_member
   39                 | enum_member_list TOKEN_COMMA

   40 enum_member: TOKEN_ID
   41            | TOKEN_ID TOKEN_ASSIGN TOKEN_NUM
   42            | TOKEN_ID TOKEN_ASSIGN TOKEN_MINUS TOKEN_NUM

   43 struct_declaration: TOKEN_STRUCT TOKEN_ID TOKEN_LEFT_BRACE struct_union_member_list TOKEN_RIGHT_BRACE TOKEN_SEMI

   44 union_declaration: TOKEN_UNION TOKEN_ID TOKEN_LEFT_BRACE struct_union_member_list TOKEN_RIGHT_BRACE TOKEN_SEMI

   45 struct_union_member_list: struct_member
   46                         | struct_union_member_list struct_member

   47 struct_member: var_preamble TOKEN_ID TOKEN_SEMI
   48              | var_preamble TOKEN_ID arr_size TOKEN_SEMI

   49 if_statement: TOKEN_IF TOKEN_LEFT_PARENTHESES exp TOKEN_RIGHT_PARENTHESES local_statement
   50             | TOKEN_IF TOKEN_LEFT_PARENTHESES exp TOKEN_RIGHT_PARENTHESES local_statement TOKEN_ELSE local_statement

   51 switch_statement: TOKEN_SWITCH TOKEN_LEFT_PARENTHESES exp TOKEN_RIGHT_PARENTHESES TOKEN_LEFT_BRACE switch_body TOKEN_RIGHT_BRACE

   52 switch_body: case_list default_clause
   53            | case_list
   54            | default_clause

   55 case_list: case_clause
   56          | case_list case_clause

   57 case_clause: TOKEN_CASE TOKEN_NUM TOKEN_COLON local_statement_list
   58            | TOKEN_CASE TOKEN_CNUM TOKEN_COLON local_statement_list
   59            | TOKEN_CASE TOKEN_ID TOKEN_COLON local_statement_list

   60 default_clause: TOKEN_DEFAULT TOKEN_COLON local_statement_list

   61 continue_statement: TOKEN_CONTINUE TOKEN_SEMI

   62 break_statement: TOKEN_BREAK TOKEN_SEMI

   63 return_statement: TOKEN_RETURN TOKEN_SEMI
   64                 | TOKEN_RETURN exp TOKEN_SEMI

   65 while_loop: TOKEN_WHILE TOKEN_LEFT_PARENTHESES exp TOKEN_RIGHT_PARENTHESES local_statement

   66 do_while_loop: TOKEN_DO local_statement TOKEN_WHILE TOKEN_LEFT_PARENTHESES exp TOKEN_RIGHT_PARENTHESES TOKEN_SEMI

   67 for_loop: TOKEN_FOR TOKEN_LEFT_PARENTHESES for_init_field TOKEN_SEMI for_condition TOKEN_SEMI for_assignment_field TOKEN_RIGHT_PARENTHESES local_statement

   68 for_init_field: ε
   69               | TOKEN_ID TOKEN_ASSIGN exp
   70               | var_preamble TOKEN_ID TOKEN_ASSIGN exp
   71               | var_preamble TOKEN_ID

   72 for_condition: ε
   73              | exp

   74 for_assignment_field: ε
   75                     | simple_var_assign
   76                     | compound_var_assign
   77                     | exp

   78 simple_var_assign: TOKEN_ID TOKEN_ASSIGN exp

   79 compound_var_assign: TOKEN_ID compound_assign_operator exp

   80 function_prototype: function_signature TOKEN_SEMI

   81 function_definition: function_signature compound_statement

   82 function_signature: var_preamble TOKEN_ID TOKEN_LEFT_PARENTHESES arg_list TOKEN_RIGHT_PARENTHESES

   83 arg_list: ε
   84         | arg_list TOKEN_COMMA TOKEN_ELLIPSIS
   85         | arg_list TOKEN_COMMA param_declaration
   86         | param_declaration

   87 param_declaration: var_preamble TOKEN_ID
   88                  | var_preamble TOKEN_ID arr_size
   89                  | var_preamble

   90 func_call: TOKEN_ID TOKEN_LEFT_PARENTHESES exp_list TOKEN_RIGHT_PARENTHESES

   91 exp_list: ε
   92         | exp_list TOKEN_COMMA exp
   93         | exp

   94 type_cast_specifier: TOKEN_LEFT_PARENTHESES all_type_specifiers TOKEN_RIGHT_PARENTHESES

   95 all_type_specifiers: data_type_specifier
   96                    | type_pointer

   97 type_pointer: data_type_specifier TOKEN_ASTERISK
   98             | type_pointer TOKEN_ASTERISK

   99 data_type_specifier: TOKEN_CHAR
  100                    | TOKEN_SHORT
  101                    | TOKEN_INT
  102                    | TOKEN_LONG
  103                    | TOKEN_LONG TOKEN_INT
  104                    | TOKEN_SHORT TOKEN_INT
  105                    | TOKEN_FLOAT
  106                    | TOKEN_DOUBLE
  107                    | TOKEN_LONG TOKEN_DOUBLE
  108                    | TOKEN_VOID
  109                    | TOKEN_STRUCT TOKEN_ID
  110                    | TOKEN_UNION TOKEN_ID
  111                    | TOKEN_ENUM TOKEN_ID

  112 visibility_qualifier: TOKEN_STATIC
  113                     | TOKEN_EXTERN
  114                     | TOKEN_INLINE

  115 mod_qualifier: TOKEN_CONST
  116              | TOKEN_VOLATILE

  117 sign_qualifier: TOKEN_SIGNED
  118               | TOKEN_UNSIGNED

  119 var_declaration: var_preamble id_list TOKEN_SEMI

  120 arr_size: TOKEN_LEFT_BRACKET exp TOKEN_RIGHT_BRACKET
  121         | TOKEN_LEFT_BRACKET TOKEN_RIGHT_BRACKET
  122         | arr_size TOKEN_LEFT_BRACKET exp TOKEN_RIGHT_BRACKET

  123 id_list: TOKEN_ID
  124        | TOKEN_ID TOKEN_ASSIGN exp
  125        | TOKEN_ID arr_size
  126        | id_list TOKEN_COMMA TOKEN_ID
  127        | id_list TOKEN_COMMA TOKEN_ID arr_size
  128        | id_list TOKEN_COMMA simple_var_assign

  129 var_preamble: all_type_specifiers
  130             | visibility_qualifier all_type_specifiers
  131             | mod_qualifier all_type_specifiers
  132             | sign_qualifier all_type_specifiers
  133             | visibility_qualifier mod_qualifier all_type_specifiers
  134             | visibility_qualifier sign_qualifier all_type_specifiers
  135             | mod_qualifier sign_qualifier all_type_specifiers
  136             | visibility_qualifier mod_qualifier sign_qualifier all_type_specifiers

  137 var_assignment: simple_var_assign TOKEN_SEMI
  138               | compound_var_assign TOKEN_SEMI
  139               | array_access TOKEN_ASSIGN exp TOKEN_SEMI
  140               | pointer_content TOKEN_ASSIGN exp TOKEN_SEMI
  141               | array_access compound_assign_operator exp TOKEN_SEMI
  142               | factor TOKEN_DOT TOKEN_ID TOKEN_ASSIGN exp TOKEN_SEMI
  143               | factor TOKEN_ARROW TOKEN_ID TOKEN_ASSIGN exp TOKEN_SEMI
  144               | pointer_content compound_assign_operator exp TOKEN_SEMI
  145               | factor TOKEN_DOT TOKEN_ID compound_assign_operator exp TOKEN_SEMI
  146               | factor TOKEN_ARROW TOKEN_ID compound_assign_operator exp TOKEN_SEMI

  147 exp: exp arithmetic_operator term
  148    | exp comparison_operator term
  149    | exp bitwise_operator term
  150    | exp logic_operator term
  151    | exp TOKEN_TERNARY exp TOKEN_COLON exp
  152    | term

  153 term: term priority_operator operand
  154     | operand

  155 operand: TOKEN_MINUS operand
  156        | TOKEN_INCREMENT operand
  157        | TOKEN_DECREMENT operand
  158        | TOKEN_LOGICAL_NOT factor
  159        | TOKEN_BITWISE_NOT term
  160        | type_cast_specifier factor
  161        | factor

  162 factor: TOKEN_LEFT_PARENTHESES exp TOKEN_RIGHT_PARENTHESES
  163       | array_access
  164       | TOKEN_NUM
  165       | TOKEN_ID
  166       | pointer_content
  167       | TOKEN_FNUM
  168       | TOKEN_CNUM
  169       | TOKEN_STR
  170       | TOKEN_BITWISE_AND array_access
  171       | TOKEN_BITWISE_AND TOKEN_ID
  172       | TOKEN_SIZEOF TOKEN_LEFT_PARENTHESES sizeof_operand TOKEN_RIGHT_PARENTHESES
  173       | func_call
  174       | factor TOKEN_INCREMENT
  175       | factor TOKEN_DECREMENT
  176       | factor TOKEN_DOT TOKEN_ID
  177       | factor TOKEN_ARROW TOKEN_ID

  178 sizeof_operand: all_type_specifiers
  179               | exp

  180 array_access: TOKEN_ID TOKEN_LEFT_BRACKET exp TOKEN_RIGHT_BRACKET
